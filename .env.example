# =============================================================
# Project Space — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================

# ------------------------------------------------------------
# Database — Supabase PostgreSQL
# Get this from: Supabase Dashboard → Project Settings → Database → Connection String (URI)
# Use the "Session mode" pooler URL for serverless Next.js:
# postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# ------------------------------------------------------------
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ------------------------------------------------------------
# NextAuth
# NEXTAUTH_SECRET: run `openssl rand -base64 32` to generate one
# NEXTAUTH_URL: your app URL (http://localhost:3000 for local dev)
# ------------------------------------------------------------
NEXTAUTH_SECRET="your-secret-here-run-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
